# Copie ce fichier en .env et remplis les valeurs, puis : docker compose up -d
# (ne commit JAMAIS le .env reel : il contient ta cle de chiffrement)

# Sous-domaine DuckDNS qui pointe vers l'IP de ton VPS
# Exemple : alexishub.duckdns.org
N8N_HOST=alexishub.duckdns.org

# Fuseau horaire (pour le cron du resume du matin)
TZ=Europe/Paris

# Cle de chiffrement des credentials n8n (Gmail, Anthropic, etc.)
# Genere-la une fois et ne la change plus : openssl rand -hex 32
N8N_ENCRYPTION_KEY=remplace_moi_par_un_hex_de_32_octets
